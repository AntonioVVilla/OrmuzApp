<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production default: reject any cleartext traffic. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Explicit HTTPS-only policy for the domains we actually hit. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">sedeaplicaciones.minetur.gob.es</domain>
        <domain includeSubdomains="true">tiles.openfreemap.org</domain>
    </domain-config>

    <!--
      Debug builds use a separate config at
      `android/app/src/debug/res/xml/network_security_config.xml`
      that additionally whitelists loopback/emulator addresses
      (localhost, 10.0.2.2, 10.0.3.2) for Metro. `<debug-overrides>`
      is intentionally omitted here because the Android lint rule
      `NetworkSecurityConfig` rejects `<domain>` children inside it.
    -->
</network-security-config>
